{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Student user profile with buyer and seller status",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "courseAndYear": { "type": "string" },
        "studentId": { "type": "string" },
        "universityEmail": { "type": "string", "format": "email" },
        "bio": { "type": "string" },
        "role": { "type": "string", "enum": ["buyer", "seller", "admin"] },
        "isVerified": { "type": "boolean" },
        "verificationStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"] },
        "studentIdImage": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "role", "isVerified", "createdAt"]
    },
    "Listing": {
      "title": "Product Listing",
      "description": "An item or service for sale on campus",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "sold", "archived"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "condition": { "type": "string", "enum": ["New", "Used"] },
        "quantity": { "type": "number" },
        "location": { "type": "string" },
        "contactMethod": { "type": "string" },
        "views": { "type": "number" },
        "inquiries": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "category", "sellerId", "status", "condition", "quantity", "location", "contactMethod", "createdAt"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "A conversation between buyer and seller regarding a listing",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "listingId": { "type": "string" },
        "listingTitle": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "listingId", "lastMessage", "lastMessageAt"]
    },
    "Favorite": {
      "title": "Favorite Listing",
      "description": "A listing marked as favorite by a user",
      "type": "object",
      "properties": {
        "listingId": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["listingId", "addedAt"]
    },
    "Review": {
      "title": "Product Review",
      "description": "A customer review for a listing or seller",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "listingId": { "type": "string" },
        "listingTitle": { "type": "string" },
        "sellerId": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "archived"] },
        "sellerReply": { "type": "string" },
        "approvedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "customerName", "listingId", "sellerId", "rating", "status", "createdAt"]
    },
    "SellerApplication": {
      "title": "Seller Application",
      "description": "Request to become a verified seller",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "school": { "type": "string" },
        "contactLink": { "type": "string" },
        "photoURL": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "fullName", "school", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Student profiles"
    },
    "/users/{userId}/favorites/{listingId}": {
      "schema": "Favorite",
      "description": "User favorites"
    },
    "/sellerApplications/{userId}": {
      "schema": "SellerApplication",
      "description": "Seller verification requests"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Public marketplace items"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Customer reviews"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Messaging sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": {
        "type": "object",
        "properties": {
          "senderId": { "type": "string" },
          "text": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Individual chat messages"
    }
  }
}
