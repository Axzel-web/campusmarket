rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 0. Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 1. Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- 2. Validation Blueprints ---

    // schema check (optional fields checked only if present)
    function isValidUserProfileSchema(data) {
      return (!('fullName' in data) || (data.fullName is string && data.fullName.size() <= 128)) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 128)) &&
             (!('role' in data) || (data.role in ['buyer', 'seller', 'admin'])) &&
             (!('isVerified' in data) || (data.isVerified is bool)) &&
             (!('onboarded' in data) || (data.onboarded is bool)) &&
             (!('interests' in data) || (data.interests is list)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp || data.createdAt is int)) &&
             (!('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() <= 1000)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000)) &&
             (!('courseAndYear' in data) || (data.courseAndYear is string && data.courseAndYear.size() <= 128)) &&
             (!('verificationStatus' in data) || (data.verificationStatus is string && data.verificationStatus.size() <= 128)) &&
             (!('studentId' in data) || (data.studentId is string && data.studentId.size() <= 128)) &&
             (!('studentIdImage' in data) || (data.studentIdImage is string && data.studentIdImage.size() <= 1000)) &&
             (!('universityEmail' in data) || (data.universityEmail is string && data.universityEmail.size() <= 128)) &&
             (!('contactDetails' in data) || (data.contactDetails is string && data.contactDetails.size() <= 512));
    }

    function hasRequiredProfileFields(data) {
      return data.keys().hasAll(['fullName', 'email', 'role', 'isVerified', 'createdAt']);
    }

    function isVerifiedSeller() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'buyer') == 'seller' &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isVerified', false) == true &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('verificationStatus', '') == 'approved';
    }

    function isValidListing(data) {
      // Only require all keys on creation (when resource is null)
      return (resource != null || data.keys().hasAll(['title', 'price', 'category', 'sellerId', 'status', 'condition', 'quantity', 'location', 'contactMethod', 'createdAt'])) &&
             (!('sellerId' in data) || data.sellerId == request.auth.uid) &&
             (!('status' in data) || data.status in ['active', 'sold', 'archived']) &&
             (!('createdAt' in data) || data.createdAt == (resource == null ? request.time : existing().createdAt));
    }

    function isValidChat(data) {
      return data.participants is list && 
             data.participants.size() == 2 &&
             request.auth.uid in data.participants;
    }

    function isValidMessage(data) {
      return data.senderId == request.auth.uid &&
             data.text is string && data.text.size() <= 1000 &&
             data.createdAt == request.time;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['customerId', 'customerName', 'listingId', 'sellerId', 'rating', 'status', 'createdAt']) &&
             data.customerId == request.auth.uid &&
             data.customerName is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.status == 'pending' &&
             data.createdAt is timestamp;
    }

    function isValidSellerApplication(data) {
      return data.keys().hasAll(['userId', 'fullName', 'school', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.fullName is string &&
             data.school is string &&
             data.status == 'pending' &&
             data.createdAt is timestamp;
    }

    // --- 3. Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // No bulk user scanning
      
      allow create: if isOwner(userId) && 
                      hasRequiredProfileFields(incoming()) &&
                      isValidUserProfileSchema(incoming()) && 
                      incoming().isVerified == false && // Cannot self-verify
                      incoming().role == 'buyer';      // Default role
      
      allow update: if isOwner(userId) && 
                      isValidUserProfileSchema(incoming()) &&
                      (!('email' in incoming()) || incoming().email == existing().email) &&
                      (!('role' in incoming()) || incoming().role == existing().role) &&
                      (!('isVerified' in incoming()) || incoming().isVerified == existing().isVerified) &&
                      (!('createdAt' in incoming()) || incoming().createdAt == existing().createdAt);
    }

    match /users/{userId}/favorites/{listingId} {
      allow read, write: if isOwner(userId);
    }

    match /sellerApplications/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidSellerApplication(incoming());
    }

    match /listings/{listingId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedSeller() && 
                      incoming().sellerId == request.auth.uid;
      allow update: if isOwner(existing().sellerId) && 
                      isValidListing(incoming()) &&
                      incoming().sellerId == existing().sellerId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'price', 'description', 'category', 'images', 'status', 'tags', 'condition', 'quantity', 'location', 'contactMethod', 'updatedAt', 'views', 'inquiries']);
      allow delete: if isOwner(existing().sellerId);
    }

    match /reviews/{reviewId} {
      // Public can read approved reviews for any listing
      allow read, list: if isSignedIn() && (
        resource.data.status == 'approved' || 
        resource.data.customerId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid
      );

      allow create: if isSignedIn() && isValidReview(incoming());
      
      allow update: if isSignedIn() && (
        // Seller can reply or archive
        (isOwner(existing().sellerId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['sellerReply', 'status'])) ||
        // Admin can approve/reject (not implemented here, but rules allow for future admin logic)
        (false) 
      );
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in existing().participants;
      allow create: if isEmailVerified() && isValidChat(incoming());
      allow update: if isSignedIn() && request.auth.uid in existing().participants &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt', 'archivedBy']);
      allow delete: if isSignedIn() && request.auth.uid in existing().participants;
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isEmailVerified() && isValidMessage(incoming()) &&
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow delete: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
